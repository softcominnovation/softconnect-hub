# =============================================================================
# SoftConnect 2.0 — Variáveis de Ambiente
# Copie este arquivo para .env e preencha com os valores reais.
# NUNCA commite o arquivo .env no git.
# =============================================================================

# --- Banco de dados ---
# Desenvolvimento LOCAL (Postgres rodando na máquina):
DATABASE_URL="postgresql://postgres:SUA_SENHA@127.0.0.1:5432/whatshub?schema=public"

# Em produção/dev na VPS, DATABASE_URL é montada pelo docker-compose com os vars abaixo:
# POSTGRES_PASSWORD_PROD → senha do serviço postgres_prod (stack Docker Swarm)
# POSTGRES_PASSWORD_DEV  → senha do serviço postgres_dev  (stack Docker Swarm)
# Os hostnames são hardcoded nos docker-compose: postgres_prod / postgres_dev

# --- Redis ---
# Desenvolvimento LOCAL (Redis rodando na máquina):
REDIS_URL="redis://127.0.0.1:6379/0"
# Em produção/dev na VPS, REDIS_URL é hardcoded nos docker-compose: redis_prod / redis_dev

# --- Segurança ---
# ENCRYPTION_KEY: exatamente 64 caracteres hexadecimais (= 32 bytes para AES-256-GCM)
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="GERE_UMA_CHAVE_HEX_DE_64_CHARS_AQUI"

# JWT_SECRET: string aleatória longa para assinar tokens JWT do Admin Plane
# Gere com: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="GERE_UM_SECRET_JWT_AQUI"

# Tempo de expiração do JWT admin em segundos (86400 = 24h)
ADMIN_JWT_EXPIRY=86400

# --- Performance ---
DEFAULT_RATE_LIMIT=100
PROXY_TIMEOUT_MS=15000
PROXY_MAX_RETRIES=1
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_RESET_MS=30000

# --- Audit log (write-behind buffer) ---
AUDIT_FLUSH_INTERVAL_MS=1000
AUDIT_FLUSH_BATCH_SIZE=100

# --- Adapter padrão ---
DEFAULT_ADAPTER_TYPE=evolution

# --- Seed de desenvolvimento (prisma/seed.ts) ---
SEED_VPS_LABEL="VPS Desenvolvimento"
SEED_VPS_SUBDOMAIN="vps-dev.local"
SEED_VPS_URL="http://vps-dev.local"
SEED_VPS_IP="127.0.0.1"
SEED_VPS_API_KEY="SUA_API_KEY_DA_VPS_EVOLUTION"
SEED_PRODUCT_NAME="Meu Produto Dev"
SEED_PRODUCT_SLUG="meu-produto-dev"
SEED_PRODUCT_API_KEY="sk_dev_GERE_UMA_CHAVE_AQUI"
SEED_WEBHOOK_URL="http://localhost:5678/webhook/dev"
SEED_WEBHOOK_SECRET="GERE_UM_SECRET_DE_WEBHOOK_AQUI"
